{
  "name": "tileset-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Sprite sheet editor for building Tiled-ready tilesets.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.2",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
